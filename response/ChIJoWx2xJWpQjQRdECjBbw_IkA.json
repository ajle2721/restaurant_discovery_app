      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT21aTFp6ZDRWVWhGTVRkcFluSkpXV2QzTVd4dFRtYxAB!2m1!1s0x3442a995c4766ca1:0x40223fbc05a34074"
