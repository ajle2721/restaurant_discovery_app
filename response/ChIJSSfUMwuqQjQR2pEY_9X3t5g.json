      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2psekxXcENUalJvVTNwc2RsbDBjVzVKTWxOcVgwRRAB!2m1!1s0x3442aa0b33d42749:0x98b7f7d5ff1891da"
