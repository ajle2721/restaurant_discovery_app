      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT21SdGQzbGZjM2wzYVZKTVJrZEtha0ZVVVZReFdYYxAB!2m1!1s0x3442abc972c3530b:0xe80bb2d599b6fdfd"
