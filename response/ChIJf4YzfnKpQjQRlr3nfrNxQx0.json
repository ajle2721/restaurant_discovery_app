      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT21odWJuRXphMWhUUmpWc2JFeHBURVpCWmpFNU1HYxAB!2m1!1s0x3442a9727e33867f:0x1d4371b37ee7bd96"
