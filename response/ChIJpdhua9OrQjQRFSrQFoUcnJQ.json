      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2xoVmNqUkhWV2t3Vm14NmRITnROM0pNU2twdFpWRRAB!2m1!1s0x3442abd36b6ed8a5:0x949c1c8516d02a15"
