      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2xkcVIzUkZiR1ZLWTBOamMwSmZibk53VmtRMVlVRRAB!2m1!1s0x3442a90dcced74eb:0x78c34765a0ceb460"
