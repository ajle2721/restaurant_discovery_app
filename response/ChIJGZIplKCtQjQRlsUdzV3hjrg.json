      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2pKalNFNXVkMmxWTUZKSmIyOUZOMjFYYkVsWE1IYxAB!2m1!1s0x3442ada094299219:0xb88ee15dcd1dc596"
