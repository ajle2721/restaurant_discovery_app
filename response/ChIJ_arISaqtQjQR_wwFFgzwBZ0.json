      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT25Bd1dqaGlTbFpFZGxWaWJsWnhaMncyTURocFZWRRAB!2m1!1s0x3442adaa49c8aafd:0x9d05f00c16050cff"
