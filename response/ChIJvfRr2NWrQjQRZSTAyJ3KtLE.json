      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2t4cWRucFVVamRDUTBOU2FqSXlTMEphVkVKeGRGRRAB!2m1!1s0x3442abd5d86bf4bd:0xb1b4ca9dc8c02465"
