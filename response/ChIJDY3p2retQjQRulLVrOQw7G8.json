      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2xsclMzVXlia1ZKWlVOSFpWUkNiMlJTTnpGRWFWRRAB!2m1!1s0x3442adb7dae98d0d:0x6fec30e4acd552ba"
