      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT25GTWJtOWxhRXRuT1RsdU5GWm5PRUZCWmxaMFJIYxAB!2m1!1s0x3442ac6f1dae220b:0x255990ee69e0b22d"
