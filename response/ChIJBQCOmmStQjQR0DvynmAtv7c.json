      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2psUmNHaGFYeTFGWkV3d1RtcEdORlpFV1VzeFoyYxAB!2m1!1s0x3442ad649a8e0005:0xb7bf2d609ef23bd0"
