      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2xOTlFVSnlWMlZLUTNObk0wMW1kRVJZU0ZGVVZtYxAB!2m1!1s0x3442a93e6b620a9b:0xd0fa44d7cee42b63"
