      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT214dExUTkRXazB6YUdkTVNHSnFTbEJGYW1wd1RGRRAB!2m1!1s0x3442abaa0c2539d1:0xb23587fd65b3052c"
