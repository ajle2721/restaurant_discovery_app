      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT21wQ2R6bENTMjEzUzNaYU4xOWpZbFowT1dveGVVRRAB!2m1!1s0x3442a970eb194031:0x495a1ed28e8eb058"
