      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT25ZdE1EWk5Wa3RIYURSSVkwb3RhWEF0VlVoMlVGRRAB!2m1!1s0x3442abdbf10d2cc9:0x2cae59be7567eea5"
