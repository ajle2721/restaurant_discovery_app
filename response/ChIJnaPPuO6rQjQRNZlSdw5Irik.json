      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2kxRWMwRlNkMVJOTXpKQlZHZGhMVXhwTVVWTGRHYxAB!2m1!1s0x3442abeeb8cfa39d:0x29ae480e77529935"
