      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2sxalVXTmxjVVJrVUZaYVpIbzNPVTVUVm1jMGEwRRAB!2m1!1s0x346801df111fa0d1:0xcef605d89be53936"
