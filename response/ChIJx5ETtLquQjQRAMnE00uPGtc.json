      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2s0MWNXZERORUZuUkRSVFdsQlJSVUpQU25BdGFuYxAB!2m1!1s0x3442aebab41391c7:0xd71a8f4bd3c4c900"
