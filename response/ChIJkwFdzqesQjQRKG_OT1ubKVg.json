      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT25rdFpVMUZlSEZYV1ZCTFVWUnpORFEzTkdKSkxYYxAB!2m1!1s0x3442aca7ce5d0193:0x58299b5b4fce6f28"
