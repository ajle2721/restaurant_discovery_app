      "publishTime": "2026-01-23T07:20:06.903189134Z",
      "flagContentUri": "https://www.google.com/local/content/rap/report?postId=Ci9DQUlRQUNvZENodHljRjlvT25oeVp6RkpObkJLUnpkMVVsRTVPUzFJZEV4YVpIYxAB&d=17924085&t=1",
      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT25oeVp6RkpObkJLUnpkMVVsRTVPUzFJZEV4YVpIYxAB!2m1!1s0x3442abfb2b716dc7:0x9937831651fa4927"
