      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2tNMU5VOVdaMUkwZUVORk9WcEZabFJuUjBsMFZrRRAB!2m1!1s0x3442a9ee283f9b1b:0xff1cc963f0e15a06"
