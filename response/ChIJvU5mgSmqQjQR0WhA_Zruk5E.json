      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2xRNWFITnRSazVCY21KZlRucHNUa1pSVlRaYWNWRRAB!2m1!1s0x3442aa2981664ebd:0x9193ee9afd4068d1"
