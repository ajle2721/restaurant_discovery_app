      "text": {
        "text": "木柵區公所旁用餐的好選擇，東坡肉很讚！",
        "languageCode": "zh-Hant"
      },
      "originalText": {
        "text": "木柵區公所旁用餐的好選擇，東坡肉很讚！",
        "languageCode": "zh-Hant"
      },
      "authorAttribution": {
        "displayName": "Daffy Lin",
