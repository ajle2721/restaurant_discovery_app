      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT2xWTVlqTkJNM0pIUmxCalR6UnFOelp4VWt4UVgyYxAB!2m1!1s0x3442aa71287cb3f7:0xe48acd19097c26c3"
