      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sChZDSUhNMG9nS0VJQ0FnTURvc2Vic1d3EAE!2m1!1s0x3442aa71287cb3f7:0xe48acd19097c26c3"
